{
  "name": "@hokkeung/astro-excalidraw-editable",
  "type": "module",
  "version": "0.1.9",
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "description": "Editable Excalidraw diagrams for Astro content, with a dev-only save endpoint.",
  "homepage": "https://github.com/ZXQ2023/astro-excalidraw-editable#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZXQ2023/astro-excalidraw-editable.git"
  },
  "bugs": {
    "url": "https://github.com/ZXQ2023/astro-excalidraw-editable/issues"
  },
  "keywords": [
    "astro",
    "excalidraw",
    "mdx",
    "remark"
  ],
  "exports": {
    ".": {
      "types": "./dist/Excalidraw.astro.d.ts",
      "default": "./dist/Excalidraw.astro"
    },
    "./integration": {
      "types": "./dist/integration.d.ts",
      "default": "./dist/integration.js"
    },
    "./remark-plugin": {
      "types": "./dist/remark-plugin.d.ts",
      "default": "./dist/remark-plugin.js"
    },
    "./react": {
      "types": "./dist/react/ExcalidrawEditable.d.ts",
      "default": "./dist/react/ExcalidrawEditable.js"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin.d.ts",
      "default": "./dist/vite-plugin.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "node scripts/build.js && vite build --watch",
    "build": "node scripts/build.js",
    "example:dev": "pnpm build && pnpm --parallel --filter @hokkeung/astro-excalidraw-editable --filter astro-excalidraw-editable-basic-example dev",
    "example:build": "pnpm build && pnpm --filter astro-excalidraw-editable-basic-example build",
    "lint": "eslint .",
    "prepack": "node scripts/build.js",
    "release": "node scripts/publish.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@astrojs/react": "^5.0.0",
    "@excalidraw/excalidraw": "^0.18.1",
    "astro": "^5.0.0",
    "react": "^17.0.2 || ^18.2.0 || ^19.0.0",
    "react-dom": "^17.0.2 || ^18.2.0 || ^19.0.0"
  },
  "devDependencies": {
    "@astrojs/react": "^5.0.0",
    "@eslint/js": "^10.0.1",
    "@excalidraw/excalidraw": "^0.18.1",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^5.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.3"
  }
}
